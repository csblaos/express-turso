{
  "name": "turso-express-starter",
  "version": "1.0.0",
  "private": true,
  "description": "Node.js Express TypeScript starter with Turso",
  "main": "dist/Server.js",
  "scripts": {
    "dev": "concurrently -n api,web -c blue,green \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "tsx watch src/Server.ts",
    "dev:web": "npm --prefix frontend run dev",
    "db:introspect": "node script/turso-db/inspect-app-db.mjs",
    "db:generate-models": "node script/turso-db/generate-models.mjs",
    "build": "npm run build:api && npm run build:web",
    "build:api": "tsc",
    "build:web": "npm --prefix frontend run build",
    "lint:fix": "eslint . --ext .ts --fix",
    "serve": "node dist/Server.js",
    "preview:web": "npm --prefix frontend run preview",
    "start": "node dist/Server.js"
  },
  "dependencies": {
    "@libsql/client": "^0.15.15",
    "@types/express": "^5.0.1",
    "@types/node": "^22.13.10",
    "@upstash/redis": "^1.37.0",
    "axios": "^1.12.2",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "module-alias": "^2.2.3",
    "redis": "^5.12.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "concurrently": "^9.2.1",
    "eslint": "^8.57.0",
    "eslint-plugin-unused-imports": "^3.1.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
